.image
  .row
    .col-md-3
      .left_controls
        .select_theme
          = render 'work/button_theme_select'
          %br

    .col-md-9
      .image_display
        .row.image
          .col-md-12
            %h2.up-theme{title: "theme_name"}
              #{@selected_theme}

          .col-md-12
            %h2.up{title: "Image file name"}
              #{@selected_image_name}

          .col-md-1
            .img-left-side
              %h3{title: "list to previous image"}
                %i.fa.fa-chevron-circle-left.strong

          .col-md-10
            .img-center{title: "Default image"}
              %img{alt: "Default Image", src: "/assets/pictures/default.jpg", title: "Default image", style: "width:100%; height:100%;"}
              .image_user_value{title: "Expert value"}
            .image_diag{ style: "text-align: center; margin-top: 20px; display: none;" }
              %h3= t('.evaluate_title')
              .btn-group
                - (1..5).each do |val|
                  %button.btn.btn-lg.btn-primary.value-button{ data: { value: val } }= val

          .col-md-1
            .img-right-side
              %h3{title: "list to next image"}
                %i.fa.fa-chevron-circle-right

:javascript
  $(document).on('click', '.img-right-side', function() {
    $.ajax({
      type: "get",
      url: "api/next_image",
      data: {
        index: window.currentImageIndex,
        theme_id: window.selectedThemeId,
        length: window.themeImagesSize
      },
      dataType: 'json'
    }).done(function (data) {
      updateImageData(data);
    });
  });

  $(document).on('click', '.img-left-side', function() {
    $.ajax({
      type: "get",
      url: "api/prev_image",
      data: {
        index: window.currentImageIndex,
        theme_id: window.selectedThemeId,
        length: window.themeImagesSize
      },
      dataType: 'json'
    }).done(function (data) {
      updateImageData(data);
    });
  });

   function updateImageData(data) {
    window.currentImageIndex = data.new_image_index;
    window.currentImageId = data.image_id; // Запоминаем ID текущей картинки!

    $('.image_display h2.up').html(data.name);
    var pathImage = "/assets/pictures/" + data.file;
    $(".img-center img").attr({src: pathImage});


    $('.image_diag').show();


    if (data.user_valued === 1) {
      $('.image_user_value').html("#{t('.your_value')}" + data.value);
    } else {
      $('.image_user_value').html("");
    }
  }


  $(document).on('click', '.value-button', function() {
    var userValue = $(this).data('value');

    $.ajax({
      type: "get",
      url: "api/save_value",
      data: {
        image_id: window.currentImageId,
        theme_id: window.selectedThemeId,
        value: userValue
      },
      dataType: 'json'
    }).done(function (data) {

      $('.img-right-side').click();
    });
  });